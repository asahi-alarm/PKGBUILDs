pkgname=asahi-calamares-configs
pkgver=20260319
pkgrel=1
pkgdesc='Asahi Linux Calamares setup configs'
arch=('any')
url='http://asahilinux.org'
license=('MIT')
depends=(calamares)
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/asahi-alarm/${pkgname}/archive/refs/tags/${pkgver}.tar.gz")
sha256sums=('0cd05ba449aa2d644af1fa3a04938ba9f267e82311c7bf0b3603c71993369ec5')
b2sums=('2506d0499267b2dd864797dcbd2b37c6f21db2214d14659927032fb1fe5407dc68f63d57321f855d2d1ff827e1fe544d56306d22ce5ec919dfc083ca9bf6ff1f')

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  make PREFIX=/usr DESTDIR=${pkgdir} install

  install -Dm644 "$srcdir/${pkgname}-${pkgver}/LICENSE" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
